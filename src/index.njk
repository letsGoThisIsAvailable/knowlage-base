<link rel="stylesheet" href="/css/style.css">

<h1>All Notes</h1>

<ul>
{% for note in collections.notes %}
  <li>
    <a href="{{ note.url }}">{{ note.data.title }}</a>
  </li>
{% endfor %}
</ul>

<h1>All Tags</h1>

<ul>
{% for tag, notes in collections.tags %}
  <li>
    <a href="/tags/{{ tag }}/">{{ tag }}</a>
  </li>
{% endfor %}
</ul>